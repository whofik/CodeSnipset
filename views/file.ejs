<%- include('./layout/header') %>

<div class="animate-load">
  <a href="/" class="back-btn">
    <i class="fas fa-arrow-left"></i>
    Back to Home
  </a>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="card card-padded alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <% if (typeof title !== 'undefined' && title) { %>
    <div class="page-header">
      <h2 class="page-title">
        <div class="logo-icon" style="width: 44px; height: 44px;">
          <i class="fas fa-file-code"></i>
        </div>
        <div>
          <%= title %>
          <% if (typeof description !== 'undefined' && description) { %>
            <p class="page-desc" style="margin-top: 6px; font-size: 13px;"><%= description %></p>
          <% } %>
        </div>
      </h2>
    </div>
  <% } %>

  <% if (typeof code !== 'undefined' && code !== null) { %>
    <div class="code-viewer">
      <div class="code-header">
        <div style="display: flex; align-items: center; gap: 12px;">
          <div class="code-dots">
            <span class="code-dot red"></span>
            <span class="code-dot yellow"></span>
            <span class="code-dot green"></span>
          </div>
          <span class="code-filename"><%= typeof filename !== 'undefined' ? filename : 'code' %></span>
        </div>
        <button type="button" class="btn btn-black" id="copyBtn" style="padding: 10px 14px; font-size: 12px;">
          <i class="far fa-copy"></i>
          <span id="copyText">Copy</span>
        </button>
      </div>

      <div class="code-content">
        <pre class="line-numbers"><code class="language-<%= typeof language !== 'undefined' && language ? language : 'javascript' %>"><%= typeof code !== 'undefined' ? code : '' %></code></pre>
      </div>

      <div class="code-footer">
        <span>
          <i class="fas fa-code"></i>
          <%= typeof lines !== 'undefined' && lines ? lines.length : 0 %> lines
        </span>
      </div>
    </div>

    <textarea id="codeContent" class="hidden"><%- code %></textarea>
  <% } else { %>
    <div class="card card-padded alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span>Code not available</span>
    </div>
  <% } %>

  <div class="action-buttons">
    <a href="/" class="btn btn-outline">
      <i class="fas fa-home"></i>
      Home
    </a>
    <a href="/admin?edit=<%= typeof filename !== 'undefined' ? encodeURIComponent(filename) : '' %>" class="btn btn-black">
      <i class="fas fa-edit"></i>
      Edit
    </a>
    <a href="/actions/delete/<%= typeof gistId !== 'undefined' ? gistId : '' %>?filename=<%= typeof filename !== 'undefined' ? encodeURIComponent(filename) : '' %>" class="btn btn-danger">
      <i class="fas fa-trash"></i>
      Delete
    </a>
  </div>
</div>

<%- include('./layout/footer') %>
