<%- include('./layout/header') %>

<div class="animate-load">
  <div class="mb-8">
    <h1 class="page-title">
      <div class="logo-icon">
        <i class="fas fa-plus-circle"></i>
      </div>
      Create New Snippet
    </h1>
    <p class="page-desc">Add a new code snippet to your collection with syntax highlighting and version control</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
    <div class="card card-padded alert alert-error">
      <i class="fas fa-exclamation-circle"></i>
      <span><%= error %></span>
    </div>
  <% } %>

  <% if (typeof success !== 'undefined' && success) { %>
    <div class="card card-padded alert alert-success">
      <i class="fas fa-check-circle"></i>
      <span><%= success %></span>
    </div>
  <% } %>

  <div class="card card-padded" style="max-width: 750px;">
    <form id="addSnippetForm">
      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-file"></i> Filename
        </label>
        <input type="text" id="filename" name="filename" placeholder="example.js" required
          class="form-input" pattern="[a-zA-Z0-9._-]+" autocomplete="off">
        <p class="form-hint">Use letters, numbers, dots, hyphens, or underscores only</p>
      </div>

      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-align-left"></i> Description
        </label>
        <input type="text" id="description" name="description" placeholder="Brief description of your snippet"
          class="form-input" autocomplete="off">
      </div>

      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-code"></i> Code
        </label>
        <textarea id="code" name="code" rows="12" placeholder="console.log('Hello, World!');" required
          class="form-input form-textarea"></textarea>
      </div>

      <div class="form-group">
        <label class="form-label">
          <i class="fas fa-key"></i> Secret Key
        </label>
        <input type="password" id="secret_key" name="secret_key" placeholder="Enter your secret key" required
          class="form-input" autocomplete="off">
        <p class="form-hint">Required for authentication to manage snippets</p>
      </div>

      <button type="submit" class="btn btn-black" style="width: 100%; padding: 14px; margin-top: 8px; font-size: 15px;">
        <i class="fas fa-plus"></i>
        Create Snippet
      </button>
    </form>
  </div>

  <div class="mt-8">
    <a href="/" class="back-btn">
      <i class="fas fa-arrow-left"></i>
      Back to Home
    </a>
  </div>

  <% if (typeof editSnippet !== 'undefined' && editSnippet) { %>
    <div class="card card-padded" style="max-width: 750px; margin-top: 32px;">
      <h2 class="page-title" style="font-size: 22px; margin-bottom: 24px;">
        <div class="logo-icon">
          <i class="fas fa-edit"></i>
        </div>
        Edit Snippet
      </h2>

      <form id="editSnippetForm">
        <input type="hidden" id="edit_gistId" value="<%= editSnippet.gistId %>">
        <input type="hidden" id="edit_filename" value="<%= editSnippet.filename %>">

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-file"></i> Filename
          </label>
          <input type="text" id="edit_filename_display" disabled
            class="form-input" style="background: var(--bg-tertiary); color: var(--text-muted); cursor: not-allowed;"
            value="<%= editSnippet.filename %>">
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-align-left"></i> Description
          </label>
          <input type="text" id="edit_description" class="form-input"
            value="<%= editSnippet.description %>">
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-code"></i> Code
          </label>
          <textarea id="edit_code" rows="12" class="form-input form-textarea"><%= editSnippet.code %></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">
            <i class="fas fa-key"></i> Secret Key
          </label>
          <input type="password" id="edit_secret_key" required class="form-input" autocomplete="off">
        </div>

        <div style="display: flex; gap: 12px;">
          <button type="submit" class="btn btn-black" style="flex: 1;">
            <i class="fas fa-save"></i>
            Save Changes
          </button>
          <a href="/admin" class="btn btn-outline" style="flex: 1;">
            <i class="fas fa-times"></i>
            Cancel
          </a>
        </div>
      </form>
    </div>
  <% } %>
</div>

<%- include('./layout/footer') %>
